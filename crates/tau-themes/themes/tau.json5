// Built-in "tau" theme.
//
// Style names use dot-separated hierarchy:
//   category.element[.variant]
{
  styles: {
    // -- User input --
    "user.prompt":          { bold: true },
    "user.prompt.queued":   { fg: "dark_grey" },

    // -- Agent responses --
    "agent.response":       { fg: "blue", italic: true },
    "agent.pending":        { fg: "dark_grey" },
    "agent.thinking":       { fg: "dark_grey", italic: true },

    // -- Tool execution --
    // A tool-call block is a `tool.output` span with nested name,
    // args, and status spans. Nested styles override only attributes
    // they specify, so theme authors can put shared styling on the
    // whole tool line and refine individual parts below.
    "tool.output":          { },
    "tool.name":            { fg: "yellow" },
    "tool.args":            { },
    "tool.status.success":  { fg: "green" },
    "tool.status.error":    { fg: "red" },
    "tool.status.info":     { fg: "blue" },
    "shell.output":         { },
    "progress.indicator":   { fg: "cyan", bold: true },

    // -- Extensions --
    "extension.lifecycle":  { fg: "dark_grey" },
    "extension.status":     { },

    // -- Sessions --
    "session.status":       { },

    // -- System --
    "system.info":          { fg: "dark_grey" },
    "system.info.important": { fg: "red", bold: true },
    "system.disconnect":    { fg: "red", bold: true },
    "system.path":          { fg: "blue" },
    "system.status":        { },

    // -- Status bar --
    "model.status":         { fg: "dark_grey" },
    "status.model":         { fg: "dark_grey" },
    "status.role":          { fg: "dark_yellow" },
    "status.session":       { fg: "cyan" },
    "status.context":       { fg: "blue" },
    "status.effort":        { fg: "yellow" },
    "status.verbosity":     { fg: "magenta" },
    "status.service_tier":  { fg: "green" },
    "status.tools":         { fg: "dark_yellow" },
    "redraw.counter":       { fg: "red" },

    // -- Token stats --
    "token.stats":                  { fg: "dark_grey" },
    "token.stats.symbol.delta":     { bold: true },
    "token.stats.symbol.sigma":     { bold: true },
    "token.stats.symbol.up":        { },
    "token.stats.symbol.down":      { },
    "token.stats.metric.cache_hit": { },
    "token.stats.metric.cache_warn": { fg: "dark_yellow" },
    "token.stats.metric.cache_miss": { fg: "red" },
    "token.stats.metric.input":     { },
    "token.stats.metric.output":    { },
    "token.stats.metric.latency":   { },

    // -- Prompt --
    "prompt.marker":        { bold: true },

    // -- Completion menu --
    "completion.label":     { fg: "green" },
    "completion.desc":      { fg: "dark_grey" },
    "completion.selected":  { fg: "white", bg: "dark_blue", bold: true },

    // -- Banner --
    "banner.accent":        { fg: "yellow" },
    "banner.logo":          { fg: "yellow" },
    "banner.name":          { fg: "white", bold: true },
    "banner.version":       { fg: "dark_grey" },
    "banner.build":         { fg: "dark_grey" },
    "banner.pun":           { fg: "dark_yellow" },

    // -- Diffs --
    // Plain `+`/`-` lines tint the whole row. `Modify` lines (single-
    // line edits with intra-line word diff) paint context in the
    // base color and use the `.inline` inverted styles to highlight
    // just the changed tokens.
    "diff.added":           { fg: "green" },
    "diff.removed":         { fg: "red" },
    "diff.context":         { fg: "dark_grey" },
    "diff.hunk_header":     { fg: "cyan" },
    "diff.added.inline":    { fg: "black", bg: "green", bold: true },
    "diff.removed.inline":  { fg: "black", bg: "red",   bold: true },
  }
}
